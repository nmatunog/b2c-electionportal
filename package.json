    "db:studio": "prisma studio",
    "db:import-users": "tsx scripts/import-official-users.ts",
    "db:normalize-b2c-ids": "tsx scripts/normalize-b2c-ids.ts",
    "db:reset:preview": "node --import tsx scripts/reset-preview-election-data.ts",
