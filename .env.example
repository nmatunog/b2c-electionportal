# --- Supabase (recommended) ---
# Create a project at https://supabase.com → Project Settings → Database.
# Optional: create a dedicated `prisma` DB user (see Supabase Prisma guide).

# App + PrismaClient: Supavisor transaction mode (port 6543). Append pgbouncer=true.
# Dashboard: Connect → choose "Prisma" / ORM or copy the Transaction pooler URI.
DATABASE_URL="postgresql://prisma.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma CLI (migrate dev, migrate deploy, db pull): Session pooler or direct connection (port 5432).
# Do not use transaction mode here — migrations need advisory locks.
DIRECT_URL="postgresql://prisma.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Full guide: https://supabase.com/docs/guides/database/prisma

# --- Local Postgres (Docker, etc.) ---
# Use one URL for both; leave DIRECT_URL unset.
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/mydb?schema=public"
